# 資料庫 URL - SQLite 相對路徑或絕對路徑
# Database URL - SQLite relative or absolute path
# Windows: sqlite://./nas.db 或 sqlite://C:/path/to/nas.db
# Linux: sqlite://./nas.db 或 sqlite:///var/lib/koimsurai-nas/nas.db
DATABASE_URL=sqlite://./nas.db

# 儲存路徑 - 使用相對路徑會自動適應平台
# Storage path - relative paths work cross-platform
# Windows: storage 或 C:/nas-data/storage
# Linux: storage 或 /data/nas/storage
STORAGE_PATH=storage

# 日誌等級
# Log level
RUST_LOG=info

# Session 密鑰 (至少 64 字元的隨機字串)
# Session secret (at least 64 random characters)
SESSION_SECRET=change_me_to_a_secure_random_string_at_least_64_chars

# ============================================================
#                    性能調優配置
#                 Performance Tuning
# ============================================================

# --- 資料庫配置 Database Configuration ---
# 最大連線數 (開發環境 5, 伺服器建議 20-50)
# Max database connections (dev: 5, server: 20-50)
DATABASE_MAX_CONNECTIONS=5

# MMAP 大小 (MB) - 記憶體映射檔案快取
# MMAP size in MB - memory-mapped file cache
# 開發環境: 64, 伺服器 (64GB RAM): 256-512
DATABASE_MMAP_SIZE_MB=64

# --- 搜尋引擎配置 Search Engine (Tantivy) ---
# 索引緩衝區大小 (MB) - 影響索引速度和記憶體使用
# Index buffer size in MB - affects indexing speed and memory
# 開發環境: 50, 伺服器: 200-500
SEARCH_INDEX_BUFFER_MB=50

# 批次提交大小 - 每 N 個文件提交一次
# Batch commit size - commit after every N files
SEARCH_BATCH_SIZE=100

# 自動提交間隔 (秒)
# Auto-commit interval in seconds
SEARCH_COMMIT_INTERVAL_SECS=5

# --- 轉檔配置 Transcoding Configuration ---
# 最大並行轉檔數 - 取決於 CPU/GPU 核心數
# Max concurrent transcodes - depends on CPU/GPU cores
# 開發環境: 2, 伺服器 (RTX 5060 Ti): 4-8
MAX_CONCURRENT_TRANSCODES=2

# 是否啟用 GPU 加速 (需要 NVIDIA/AMD/Intel GPU)
# Enable GPU acceleration (requires NVIDIA/AMD/Intel GPU)
# 自動檢測，設為 false 可強制使用 CPU
USE_GPU_TRANSCODE=auto

# --- 索引器配置 Indexer Configuration ---
# 是否在啟動時執行完整掃描
# Run full scan on startup
INDEXER_FULL_SCAN_ON_STARTUP=false

# 快速掃描間隔 (分鐘) - 輕量級一致性檢查
# Quick scan interval in minutes - lightweight consistency check
INDEXER_QUICK_SCAN_INTERVAL_MINS=30

# ============================================================
#           生產環境完整配置範例 (64GB RAM + RTX 5060 Ti)
#           Production Config Example (64GB RAM + RTX 5060 Ti)
# ============================================================
# DATABASE_URL=sqlite:///var/lib/koimsurai-nas/data/nas.db
# STORAGE_PATH=/data/nas/storage
# RUST_LOG=info
# SESSION_SECRET=<your_secure_64_char_random_string>
#
# # 高性能資料庫
# DATABASE_MAX_CONNECTIONS=50
# DATABASE_MMAP_SIZE_MB=512
#
# # 大緩衝區搜尋引擎
# SEARCH_INDEX_BUFFER_MB=500
# SEARCH_BATCH_SIZE=200
# SEARCH_COMMIT_INTERVAL_SECS=10
#
# # GPU 加速轉檔
# MAX_CONCURRENT_TRANSCODES=6
# USE_GPU_TRANSCODE=auto
#
# # 索引器
# INDEXER_FULL_SCAN_ON_STARTUP=false
# INDEXER_QUICK_SCAN_INTERVAL_MINS=60
